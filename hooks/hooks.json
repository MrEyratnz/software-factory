{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/bootstrap.sh", "timeout": 30 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-status.sh", "timeout": 20 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/guard-bash-writes.sh", "timeout": 20 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/guard-commit.sh", "timeout": 30 }
        ]
      },
      {
        "matcher": "Bash|mcp__github__push_files|mcp__github__create_or_update_file|mcp__github__delete_file|mcp__github__merge_pull_request",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/guard-release.sh", "timeout": 30 }
        ]
      },
      {
        "matcher": "mcp__github__create_or_update_file|mcp__github__push_files|mcp__github__delete_file",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/guard-mcp-commit.sh", "timeout": 20 }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/guard-scope.sh", "timeout": 20 }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/guard-roadmap.sh", "timeout": 20 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/record-green.sh", "timeout": 30 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/record-release-proof.sh", "timeout": 30 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ledger-record.sh", "timeout": 20 }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-drift.sh", "timeout": 60 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "reviewer|panelist|proposer",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-handoff.sh", "timeout": 20 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debt-reconcile.sh", "timeout": 45 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/release-cleanup.sh", "timeout": 20 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/loop-guard.sh", "timeout": 20 }
        ]
      }
    ]
  }
}
