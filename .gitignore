node_modules/
*.log
.DS_Store
dist/
coverage/
*.tgz

# Factory runtime state — generated by the hooks (green receipts, ledger,
# review/panel artifacts, active-agent marker); never committed.
# .factory/config.json (a repo's committed factory config) is intentionally
# NOT ignored.
.factory/state/
.factory/review/
.factory/panel/
.factory/ledger.jsonl
.factory/active-agent

# One-time GitHub App private keys persisted by bootstrap.sh so a partial run can
# resume (0600). Deleted once the secret+variable are stored; must never commit.
factory-ops/state/.bootstrap-apps/

# Personal Claude Code overrides — never committed (the shared project
# settings live in .claude/settings.json, which IS committed).
.claude/settings.local.json
