{
  "stack": "node",
  "roadmapPath": "docs/ROADMAP.md",
  "adrDir": "docs/adr",
  "releaseBranch": "main",
  "sourceRegex": "^src/",
  "testRegex": "(\\.test\\.|\\.spec\\.|_test\\.|/tests?/|\\.feature$)",
  "testCommandRegex": "(npm ((run|-s) )?test|node --test|vitest)",
  "releaseVerbRegex": "(git tag|gh release create|npm publish|npm version |release-please)",
  "testCommand": "npm test",
  "maxIterations": 10,
  "enforcement": {
    "requireGreenReceiptOnCommit": true,
    "requireTestsFirst": true,
    "conventionalCommitLint": true,
    "requireReleaseProof": true,
    "enforceProjectDirScope": true,
    "protectTrustRoots": true
  },
  "gates": {
    "typecheck": "npm run typecheck",
    "boundaries": "npm run check:boundaries",
    "unit": "npm run test:unit",
    "bdd": "npm run test:bdd",
    "build": "npm run build"
  },
  "generators": [],
  "otel": {
    "enabled": false,
    "endpoint": "http://localhost:4318",
    "exporter": "otlphttp"
  }
}
